doctype html
html
  head
    meta(name='viewport', content='width=device-width, initial-scale=1.0')
    meta(http-equiv='Content-Type', content='text/html; charset=UTF-8')
    title= subject
    include _style
  body(style='margin: 0; padding: 0; font-family: Arial, sans-serif; background-color: #f5f5f5;')
    table.body(role='presentation', border='0', cellpadding='0', cellspacing='0', width='100%', style='border-collapse: collapse;')
      tr
        td(align='center', valign='top', style='padding: 20px 0;')
          table.container(role='presentation', border='0', cellpadding='0', cellspacing='0', width='600', style='border-collapse: collapse; width: 100%; max-width: 600px;')
            tr
              td(style='background-color: #ffffff; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.05);')
                // START EMAIL WRAPPER
                .email-wrapper(style='padding: 0; margin: 0;')
                  // HEADER
                  table.header(role='presentation', border='0', cellpadding='0', cellspacing='0', width='100%', style='border-collapse: collapse;')
                    tr
                      td(align='center', style='padding: 30px 20px;')
                        img.logo(src='https://api.winsubz.com/img/logo.png', alt='Winsubz', width='120', style='display: block; margin: 0 auto; max-width: 120px; height: auto;')
                        h1.header-title(style='font-size: 24px; font-weight: bold; margin: 15px 0 5px;') Winsubz
                        p.header-subtitle(style='font-size: 14px; margin: 0;') Your trusted digital platform for fast and reliable airtime top-ups, cheap data bundles, electricity bill payments, and cable TV subscriptions. Secure, affordable and delivered instantly.
                  
                  // MAIN CONTENT
                  table.content(role='presentation', border='0', cellpadding='0', cellspacing='0', width='100%', style='border-collapse: collapse;')
                    tr
                      td(style='padding: 20px;')
                        .content-inner(style='margin: 0; padding: 0;')
                          // MAIN MESSAGE
                          .message(style='margin: 0; padding: 0;')
                            block content
                  
                  // FOOTER
                  table.footer(role='presentation', border='0', cellpadding='0', cellspacing='0', width='100%', style='border-collapse: collapse;')
                    tr
                      td(style='padding: 20px; background-color: #f8f9fa; border-radius: 0 0 8px 8px; text-align: center;')
                        .footer-links(style='margin-bottom: 15px;')
                          a.footer-link(href='https://www.winsubz.com', style='color: #4a90e2; text-decoration: none; margin: 0 10px; display: inline-block;') Visit Website
                          a.footer-link(href='https://yourplatform.com/support', style='color: #4a90e2; text-decoration: none; margin: 0 10px; display: inline-block;') Support Center
                          a.footer-link(href='https://yourplatform.com/help', style='color: #4a90e2; text-decoration: none; margin: 0 10px; display: inline-block;') Help Center
                        
                        .social-links(style='margin-bottom: 15px;')
                          a.social-icon(href='#', style='color: #6c757d; text-decoration: none; margin: 0 8px; display: inline-block;') Twitter
                          a.social-icon(href='#', style='color: #6c757d; text-decoration: none; margin: 0 8px; display: inline-block;') Facebook
                          a.social-icon(href='#', style='color: #6c757d; text-decoration: none; margin: 0 8px; display: inline-block;') LinkedIn
                          a.social-icon(href='#', style='color: #6c757d; text-decoration: none; margin: 0 8px; display: inline-block;') Instagram
                        
                        p.copyright(style='font-size: 12px; color: #9ca3af; margin: 0; line-height: 1.5;')
                          | © 2026 Winsubz. All rights reserved.
                          br
                          | Bishop House, Amawire-Orji, Owerri Imo State
                          br
                          br
                          a(href='#', style='color: #9ca3af; text-decoration: none;') Unsubscribe
                          |  | 
                          a(href='#', style='color: #9ca3af; text-decoration: none;') Privacy Policy
                          |  | 
                          a(href='#', style='color: #9ca3af; text-decoration: none;') Terms of Service