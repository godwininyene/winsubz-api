doctype html
html
  head
    meta(name='viewport', content='width=device-width')
    meta(http-equiv='Content-Type', content='text/html; charset=UTF-8')
    title= subject
    include _style

  body
    table.body(role='presentation', border='0', cellpadding='0', cellspacing='0', style='width: 100%;')
      tbody
        tr
          td
          td.container
            .content
              // START EMAIL WRAPPER
              .email-wrapper
                // HEADER
                .header
                  img.logo(src='https://yourplatform.com/logo.png', alt='Vico Logo')
                  h1.header-title VICO
                  p.header-subtitle Digital Assets Exchange

                // MAIN CONTENT
                .content
                  .content-inner
                    // MAIN MESSAGE
                    .message
                      block content

                   

                // FOOTER
                .footer
                  .footer-links
                    a.footer-link(href='https://yourplatform.com') Visit Website
                    a.footer-link(href='https://yourplatform.com/support') Support Center
                    a.footer-link(href='https://yourplatform.com/help') Help Center

                  .social-links
                    a.social-icon(href='#') Twitter
                    a.social-icon(href='#') Facebook
                    a.social-icon(href='#') LinkedIn
                    a.social-icon(href='#') Instagram

                  p.copyright
                    | © 2024 Vico Digital Assets. All rights reserved.
                    br
                    | Vico Tower, 123 Crypto Avenue, Lagos, Nigeria
                    br
                    br
                    a(href='#', style='color: #9ca3af; text-decoration: none;') Unsubscribe
                    |  | 
                    a(href='#', style='color: #9ca3af; text-decoration: none;') Privacy Policy
                    |  | 
                    a(href='#', style='color: #9ca3af; text-decoration: none;') Terms of Service

          td
